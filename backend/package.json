{
  "name": "backend",
  "scripts": {
    "dev": "bun --env-file=../.env run --hot src/api.ts",
    "dev:worker": "bun --env-file=../.env run --hot src/worker.ts",
    "migrate": "bun --env-file=../.env run src/db/migrate.ts",
    "seed": "bun --env-file=../.env run scripts/seed.ts",
    "export:openapi": "bun --env-file=../.env run scripts/export-openapi.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-openapi": "1.3.0",
    "@scalar/hono-api-reference": "0.10.7",
    "better-auth": "1.6.2",
    "bullmq": "^5.73.5",
    "exceljs": "^4.4.0",
    "hono": "4.12.12",
    "ioredis": "^5.10.1",
    "minio": "^8.0.7",
    "pg": "8.20.0",
    "pino": "^9.5.0",
    "postgres": "3.4.9",
    "prom-client": "^15.1.3",
    "puppeteer-core": "^23.11.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bun": "latest",
    "@types/pg": "8.20.0",
    "pino-pretty": "^11.3.0",
    "typescript": "^6.0.2"
  }
}