{
  "openapi": "3.1.0",
  "info": {
    "title": "Reportist API",
    "version": "0.1.0"
  },
  "components": {
    "schemas": {
      "ReportMeta": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "body-composition-dynamics"
          },
          "name": {
            "type": "string",
            "example": "Body composition dynamics"
          },
          "description": {
            "type": "string"
          },
          "supportedFormats": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "xlsx"
              ]
            }
          },
          "paramsSchema": {
            "type": "object",
            "description": "JSON Schema (draft 2020-12) of report parameters"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "supportedFormats"
        ]
      },
      "Client": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "fullName": {
            "type": "string"
          },
          "gymId": {
            "type": "string",
            "format": "uuid"
          },
          "gymName": {
            "type": "string"
          },
          "city": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "fullName",
          "gymId",
          "gymName",
          "city"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/reports": {
      "get": {
        "operationId": "listReports",
        "tags": [
          "reports"
        ],
        "summary": "List available reports",
        "responses": {
          "200": {
            "description": "Registered report definitions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReportMeta"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/clients": {
      "get": {
        "operationId": "listClients",
        "tags": [
          "clients"
        ],
        "summary": "List fitness clients available for reports",
        "responses": {
          "200": {
            "description": "Clients with their gym context",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Client"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}
