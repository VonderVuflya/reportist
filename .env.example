API_PORT=3000
WEB_PORT=5173

# --- Postgres ---
POSTGRES_USER=reportist
POSTGRES_PASSWORD=reportist
POSTGRES_DB=reportist
POSTGRES_PORT=5432
DATABASE_URL=postgres://reportist:reportist@localhost:5432/reportist

# --- Auth (better-auth) ---
# 32+ chars. Generate locally: `openssl rand -base64 32`
AUTH_SECRET=dev-insecure-secret-change-me-xxxxxxxxxxxxx
AUTH_BASE_URL=http://localhost:3000
# Frontend origin allowed by CORS and trusted by better-auth redirect checks.
WEB_ORIGIN=http://localhost:5173

# --- Redis (BullMQ) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO (S3-compatible storage via minio-js) ---
# Host-facing endpoint used both by backend (host dev) and by browser
# when downloads are streamed through the backend-proxy route.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=reportist
MINIO_SECRET_KEY=reportist-dev-secret
MINIO_BUCKET=reports
MINIO_CONSOLE_PORT=9001

# --- Coolify deploy (docker-compose.yml) ---
# Public-facing FQDN for the whole app. Coolify fills this automatically
# from the `SERVICE_FQDN_FRONTEND_80` magic label and uses the same
# value for backend AUTH_BASE_URL / WEB_ORIGIN so cookies stay valid.
# For local prod-like test: `SERVICE_FQDN_FRONTEND=http://localhost:8080`
# and add `ports: ["8080:80"]` to the frontend service.
SERVICE_FQDN_FRONTEND=http://localhost:8080
