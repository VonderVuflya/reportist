{
  "name": "reportist",
  "private": true,
  "scripts": {
    "install:all": "(cd backend && bun install) && (cd frontend && bun install)",
    "dev:api": "bun --cwd backend run dev",
    "dev:web": "bun --cwd frontend run dev",
    "up": "docker compose up -d",
    "up:dev": "docker compose -f docker-compose.dev.yml up",
    "down": "docker compose down",
    "down:dev": "docker compose -f docker-compose.dev.yml down"
  }
}
